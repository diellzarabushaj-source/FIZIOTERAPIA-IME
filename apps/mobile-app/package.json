{
  "name": "fizioterapia-ime-mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "generate:assets": "node scripts/generate-assets.mjs",
    "build:preview": "npm run generate:assets && eas build --profile preview --platform all",
    "build:ios": "npm run generate:assets && eas build --profile production --platform ios",
    "build:android": "npm run generate:assets && eas build --profile production --platform android",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "sharp": "^0.34.1",
    "typescript": "~5.9.2"
  }
}
