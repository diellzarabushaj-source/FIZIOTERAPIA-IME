# Public mobile app configuration
# Do not put service role keys, Clerk secret keys, or Resend API keys here.

# Production web API backend used by the mobile patient app.
EXPO_PUBLIC_API_BASE_URL=https://fizioterapia-ime.vercel.app

# Optional local development backend.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Legacy direct Supabase keys are no longer required for the patient mobile app.
# The mobile app talks to the web API, and the web API talks to Supabase/Resend server-side.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
