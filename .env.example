# Environment identity: development | staging | production | test
APP_ENV=development

# Clerk
# Development and staging may use a test instance. Production requires Clerk production credentials.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/physiotherapist-portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/physiotherapist-portal

# Platform owner
# Keep synchronized with the owner profile in Supabase. This is not the only authorization check.
ADMIN_EMAIL=

# Patient sessions
# Use a strong, unique value in every environment. Never expose it with a NEXT_PUBLIC prefix.
PATIENT_SESSION_SECRET=
# Set to 1 only after migration 20260711_patient_session_registry.sql is applied.
# Production requires 1 so patient sessions can be individually revoked.
PATIENT_SESSION_REGISTRY_ENABLED=0

# Production monitoring
# Required in production to reveal protected health/readiness diagnostics to the monitor only.
HEALTH_MONITOR_SECRET=
# Create a Sentry JavaScript/Next.js project and copy its DSN here.
# SENTRY_DSN enables server reporting; NEXT_PUBLIC_SENTRY_DSN enables browser reporting.
# These DSNs are ingestion addresses, not authentication tokens.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Supabase
# Development and staging should not point to the production database.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Fizioterapia ime <alerts@example.test>
RESEND_REPLY_TO_EMAIL=

# Sanity public blog
NEXT_PUBLIC_SANITY_PROJECT_ID=a3wcdlcy
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-09

# App URL
# Development: local URL
# Staging: Vercel preview or staging HTTPS URL
# Production: canonical HTTPS domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile app
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
