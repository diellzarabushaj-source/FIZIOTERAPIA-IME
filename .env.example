# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/physiotherapist-portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/physiotherapist-portal

# Hidden Admin
ADMIN_EMAIL=diellzarabushaj@gmail.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend email notifications
# Create/copy this in Resend dashboard, then add it only in Vercel Environment Variables.
RESEND_API_KEY=
# For first tests use onboarding@resend.dev. Later replace with verified domain email, e.g. alerts@fizioterapiaime.com.
RESEND_FROM_EMAIL=Fizioterapia ime <onboarding@resend.dev>
RESEND_REPLY_TO_EMAIL=diellzarabushaj@gmail.com

# Sanity public blog
# These are public read-only config values. Do not put private Sanity tokens in NEXT_PUBLIC variables.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-09

# App
NEXT_PUBLIC_APP_URL=https://fizioterapia-ime.vercel.app
