# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/physiotherapist-portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/physiotherapist-portal

# Platform owner
# Keep this synchronized with the owner profile in Supabase. Do not use it as the only authorization check.
ADMIN_EMAIL=

# Patient sessions
# Required in production. Generate at least 32 random bytes and never expose it as NEXT_PUBLIC_*.
PATIENT_SESSION_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Fizioterapia ime <alerts@your-verified-domain.example>
RESEND_REPLY_TO_EMAIL=

# Sanity public blog
NEXT_PUBLIC_SANITY_PROJECT_ID=a3wcdlcy
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-09

# App
NEXT_PUBLIC_APP_URL=https://fizioterapia-ime.vercel.app
